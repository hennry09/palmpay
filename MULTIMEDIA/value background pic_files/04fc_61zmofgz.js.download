`,s=t.default.div`
  position: relative;
  /* padding: 50px 0; */

  .menuIntroduce {
    display: inline-block;
    max-width: 255px;
    padding-right: 70px;
    vertical-align: top;

    .menuTitle {
      color: #18191F;
      font-size: 22px;
      font-style: normal;
      font-weight: 600;
      line-height: 30px;
    }

    .menuDesc {
      color: #6F7B85;
      font-size: 14px;
      font-style: normal;
      font-weight: 400;
      line-height: normal;
      padding-top: 12px;
    }
  }

  .menuGroup {
    display: inline-block;
    min-width: 255px;
    max-width: 270px;
    margin-right: 70px;
    vertical-align: top;

    .linkBox {
      .linkTitle {
        cursor: pointer;
        color: #18191F;
        font-size: 18px;
        font-style: normal;
        font-weight: 500;
        line-height: normal;
      }

      .linkDesc {
        color: #6F7B85;
        font-size: 14px;
        font-style: normal;
        font-weight: 400;
        line-height: normal;
        padding-top: 4px;
      }
    }
  }

  .downloadApp {
    display: inline-block;
    position: absolute;
    top: 50px;
    right: 0;
  }
